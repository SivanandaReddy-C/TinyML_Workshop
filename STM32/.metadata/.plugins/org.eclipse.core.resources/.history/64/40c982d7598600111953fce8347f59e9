void MX_X_CUBE_AI_Init(void)
{
    ai_error err;

    /* Activation memory */
    const ai_handle activations[] =
    {
    		activations_buffer
    };

    /* Use embedded weights generated by X-CUBE-AI */
    err = ai_network_create_and_init(
            &network,
            activations,
            NULL);

    if (err.type != AI_ERROR_NONE)
    {
        printf("AI Init Failed\r\n");
        printf("Type = %d\r\n", err.type);
        printf("Code = %d\r\n", err.code);
        Error_Handler();
    }

    ai_input  = ai_network_inputs_get(network, NULL);
    ai_output = ai_network_outputs_get(network, NULL);

    printf("AI Initialized Successfully\r\n");
}


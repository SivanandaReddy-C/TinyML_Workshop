/* USER CODE BEGIN 4 */
int _write(int file, char *ptr, int len)
{
    HAL_UART_Transmit(&huart1, (uint8_t*)ptr, len, HAL_MAX_DELAY);
    return len;
}

void AI_Run(void)
{
    ai_i32 batch;

    ai_input[0].data = AI_HANDLE_PTR(input_data);

    ai_output[0].data = AI_HANDLE_PTR(&predicted_label);

    ai_output[1].data = AI_HANDLE_PTR(probabilities);

    batch = ai_network_run(network,
                           ai_input,
                           ai_output);

    if(batch != 1)
    {
        printf("Inference Error\r\n");
        return;
    }

    printf("\r\n-------------------------\r\n");

    printf("Predicted Class : %ld\r\n", predicted_label);

    printf("Probabilities:\r\n");

    for(int i=0;i<5;i++)
    {
        printf("Class %d : %.4f\r\n",
                i,
                probabilities[i]);
    }
}
/* USER CODE END 4 */

